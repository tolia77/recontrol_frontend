# Committed Vite mode env for the Phase 42.2 frontend audit.
# Loaded via `npm run dev -- --mode audit` or `npm run build -- --mode audit`.
#
# Points at the isolated audit backend (docker-compose.audit.yml, host port 3013).
# This file is NOT gitignored — it is a deterministic, committed audit config
# for the throwaway local audit stack. It never points at dev/prod (D-05).
VITE_BACKEND_URL=http://127.0.0.1:3013
VITE_WEBSOCKETS_URL=ws://127.0.0.1:3013/cable
